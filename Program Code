import hashlib
import json
import os

DB_FILE = "users.json"  # Our simple database file


def hash_password(password):
    """Convert password to SHA-256 hash"""
    return hashlib.sha256(password.encode()).hexdigest()


def load_users():
    """Load all users from JSON file"""
    if not os.path.exists(DB_FILE):
        return {}

    with open(DB_FILE, "r") as f:
        return json.load(f)


def save_users(users):
    """Save all users to JSON file"""
    with open(DB_FILE, "w") as f:
        json.dump(users, f, indent=4)


def register(username, password):
    """Create a new user account"""
    users = load_users()

    # Check if username already exists
    if username in users:
        print(f"Error: Username '{username}' is already taken.")
        return False

    # Check password length
    if len(password) < 6:
        print("Error: Password must be at least 6 characters.")
        return False

    # Hash password
    hashed = hash_password(password)

    # Save user
    users[username] = hashed
    save_users(users)

    print(f"Account created for {username}! Password stored as hash.")
    return True


def login(username, password):
    """Check if username and password match"""
    users = load_users()

    if username not in users:
        print("Error: Username not found.")
        return False

    # Hash entered password
    hashed = hash_password(password)

    if users[username] == hashed:
        print(f"\nWelcome back, {username}! Login successful.")
        return True
    else:
        print("Error: Incorrect password.")
        return False


def main():
    print("=" * 45)
    print("        SECURE LOGIN SYSTEM")
    print(" (Passwords stored as SHA-256 hashes)")
    print("=" * 45)

    while True:
        print("\n1. Register")
        print("2. Login")
        print("3. View Database (see hashes)")
        print("4. Exit")

        choice = input("\nChoose (1-4): ")

        if choice == "1":
            uname = input("Choose a username: ")
            pwd = input("Choose a password: ")
            register(uname, pwd)

        elif choice == "2":
            uname = input("Username: ")
            pwd = input("Password: ")
            login(uname, pwd)

        elif choice == "3":
            users = load_users()

            if not users:
                print("No users registered yet.")
            else:
                print("\nStored users (passwords are hashed):")
                for user, hashed in users.items():
                    print(f"{user}: {hashed[:20]}...")

        elif choice == "4":
            print("Goodbye!")
            break

        else:
            print("Invalid choice. Please enter 1, 2, 3, or 4.")


if __name__ == "__main__":
    main()
